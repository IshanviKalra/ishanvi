import pandas as pd

# Import dataset (CSV file)
# Change 'data.csv' to your file name
df = pd.read_csv('data.csv')

# Export dataset (copy to new file)
df.to_csv('exported_data.csv', index=False)

print("----- DATASET DETAILS -----\n")

# Number of rows and columns
print("Shape (rows, columns):", df.shape)

# Size (total elements)
print("Total size:", df.size)

# First 5 rows
print("\nFirst 5 rows:")
print(df.head())

# Number of missing values
print("\nMissing values:")
print(df.isnull().sum())

# Numerical columns only
num_df = df.select_dtypes(include='number')

print("\n----- NUMERICAL COLUMN ANALYSIS -----\n")

# Sum
print("Sum:")
print(num_df.sum())

# Average (Mean)
print("\nAverage:")
print(num_df.mean())

# Minimum values
print("\nMinimum values:")
print(num_df.min())

# Maximum values
print("\nMaximum values:")
print(num_df.max())